{
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },
    "files.exclude": {
    "**/README.md": true,
    "**/.gitignore": true,
    "**/app.json":true,
    "**/eslint.config.js":true,
    "**/tsconfig.json":true,
    "**/package-lock.json":true,
    "**/expo-env.d.ts":true,
    "**/node_modules":true,
    "**/.expo":true,
  }
}
